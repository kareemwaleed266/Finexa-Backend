{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": "Information",
        "WriteTo": [
            { "Name": "Console" },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/log-.txt",
                    "rollingInterval": "Day",
                    "restrictedToMinimumLevel": "Information"
                }
            }
        ],
        "Enrich": [ "FromLogContext" ]
    },
    "ConnectionStrings": {
        "DefaultConnection": ""
    },
    "JwtSettings": {
        "Secret": "",
        "Issuer": "Finexa",
        "Audience": "FinexaUsers",
        "DurationInMinutes": 60
    },
    "Urls": {
        "ApiBaseUrl": "https://localhost:7124"
    },
    "AI": {
        "BaseUrl": "https://stt-flax.vercel.app"
    }
}